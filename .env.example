# ============================================================
# DeployX — Variables d'environnement
# ============================================================
# Copiez ce fichier en .env et remplissez les valeurs.
#   cp .env.example .env
# ============================================================

# Azure DevOps — Organisation (ex: myorg)
AZDO_ORG=

# Azure DevOps — Projet (ex: MyProject)
AZDO_PROJECT=

# Azure DevOps — Personal Access Token (scope: Build Read)
AZDO_PAT=

# URL du backend FastAPI (utilisé par Streamlit)
DEPLOYX_BACKEND_URL=http://localhost:8000
